{
  "name": "portal-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "desktop:dev": "cd .. && node ui/node_modules/@tauri-apps/cli/tauri.js dev",
    "desktop:build": "cd .. && node ui/node_modules/@tauri-apps/cli/tauri.js build --no-bundle",
    "desktop:portable": "powershell -NoProfile -ExecutionPolicy Bypass -File ../desktop/scripts/build-portable.ps1",
    "ingest:critical-assets": "python scripts/critical-assets/load-duckdb.py",
    "ingest:critical-team": "python scripts/critical-team/load-duckdb.py",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@deck.gl/core": "^9.3.3",
    "@deck.gl/geo-layers": "^9.3.3",
    "@deck.gl/layers": "^9.3.3",
    "@deck.gl/react": "^9.3.3",
    "@fontsource-variable/geist": "^5.2.9",
    "@tauri-apps/api": "^2.11.1",
    "@turf/turf": "^7.3.5",
    "@vis.gl/react-maplibre": "^8.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "echarts": "^6.1.0",
    "lucide-react": "^1.17.0",
    "maplibre-gl": "^5.24.0",
    "pmtiles": "^4.4.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "shadcn": "^4.10.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.4",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
