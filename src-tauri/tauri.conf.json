{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Portal",
  "version": "0.1.0",
  "identifier": "gov.charlottenc.stormwater.portal",
  "build": {
    "beforeDevCommand": "pnpm --dir ui dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "pnpm --dir ui build",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Storm Water Asset Intelligence Portal",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "center": true,
        "resizable": true,
        "maximized": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": []
  }
}
